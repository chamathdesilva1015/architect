#include <iostream>
#include <vector>
#include <thread>
#include "processor.hpp"

// Project: {{ project_name|default("concurrent_tasks") }}
// Author: {{ author_name|default("Unknown") }}

class TaskProcessor {
public:
    TaskProcessor(size_t num_threads) : stop(false) {
        for(size_t i = 0; i < num_threads; ++i) {
            worker_threads.emplace_back([this] {
                while(true) {
                    std::function<void()> task;
                    tasks.wait_and_pop(task);
                    
                    // A special 'null' task or checking a stop flag
                    if(stop) return;
                    
                    if (task) {
                        task(); // Execute the task
                    }
                }
            });
        }
    }

    template<class F>
    void enqueue_task(F&& f) {
        tasks.push(std::forward<F>(f));
    }

    ~TaskProcessor() {
        stop = true;
        // Submit empty tasks to wake up threads
        for(size_t i = 0; i < worker_threads.size(); ++i) {
            enqueue_task([]{});
        }
        for(std::thread &worker: worker_threads) {
            if (worker.joinable()) {
                worker.join();
            }
        }
    }

private:
    std::vector<std::thread> worker_threads;
    architecture::ThreadSafeQueue<std::function<void()>> tasks;
    bool stop;
};

int main() {
    std::cout << "Starting {{ project_name|default('concurrent_tasks') }} System..." << std::endl;
    
    // User defined max_threads from architect setup
    size_t threads = {{ max_threads|default(4) }};
    std::cout << "Initializing processor with " << threads << " worker_threads." << std::endl;

    TaskProcessor processor(threads);
    
    // Example: Submitting tasks
    for(int i = 0; i < 10; ++i) {
        processor.enqueue_task([i] {
            std::cout << "Executing task " << i << " on thread " << std::this_thread::get_id() << std::endl;
        });
    }

    std::this_thread::sleep_for(std::chrono::seconds(2));
    std::cout << "Shutting down." << std::endl;
    return 0;
}
