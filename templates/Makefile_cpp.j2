CXX = g++
CXXFLAGS = -std=c++20 -Wall -Wextra -Iinclude
TARGET = build/{{ project_name|default('app') }}
SRC = src/main.cpp

all: build $(TARGET)

build:
	mkdir -p build

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) $(SRC) -o $(TARGET)

run: all
	./$(TARGET)

clean:
	rm -rf build

.PHONY: all build run clean
