:root {
  /* Minimalist Color Palette */
  --bg-color: #0d1117;
  --text-color: #c9d1d9;
  --primary-color: #58a6ff;
  --border-color: #30363d;
  
  /* Typography Scale */
  --font-base: 16px;
  --font-large: 24px;
  --font-small: 12px;
  --font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
}

body {
  background-color: var(--bg-color);
  color: var(--text-color);
  font-family: var(--font-family);
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

#app-root {
  width: 100%;
  max-width: 800px;
  padding: 2rem;
}

/* Zero-dependency performance styling */
button {
  background-color: var(--primary-color);
  color: #fff;
  border: none;
  padding: 8px 16px;
  border-radius: 6px;
  cursor: pointer;
  font-weight: bold;
}

button:hover {
  opacity: 0.9;
}
